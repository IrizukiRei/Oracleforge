<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ data extraction rules.
  Exclude everything from both cloud backup and device-to-device transfer
  so that IAP entitlement flags (save_plus, ads_removed) can never be
  carried across Google accounts or devices outside of Google Play Billing.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
